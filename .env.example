# ============================================================================
# Variables de entorno · Saleshealth CLTV
# ============================================================================
# Copia este archivo a .env y rellena los valores reales.
# El archivo .env NUNCA debe subirse a Git (lo evita .gitignore).
# ============================================================================

# Conexión PostgreSQL — usuario superadmin (postgres) que puede crear BDs
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=tu_contraseña_aquí

# Base de datos ORIGEN — la que ya tienes con los datos del proyecto
DB_NAME_SOURCE=saleshealth

# Base de datos DESTINO — la que vamos a crear con el modelo dimensional propio
DB_NAME_DWH=saleshealth_cltv
